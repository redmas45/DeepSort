APP_NAME=DeepSORT Railway Starter
APP_ENV=development
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VIDEO_SOURCE_DIR=data/videos
FRAME_WIDTH=960
FRAME_HEIGHT=540
STREAM_FPS=10
JPEG_QUALITY=80
DETECTOR_BACKEND=ultralytics
YOLO_MODEL=yolo11n.pt
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
TRACKER_BACKEND=deepsort
MAX_TRACK_AGE=30
MATCH_DISTANCE_THRESHOLD=120.0
TRACKED_CLASS_NAMES=person
