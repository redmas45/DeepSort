APP_NAME=DeepSORT Railway Starter
APP_ENV=development
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VIDEO_SOURCE_DIR=data/videos
FRAME_WIDTH=960
FRAME_HEIGHT=540
STREAM_FPS=10
JPEG_QUALITY=82
CAMERA_CAPTURE_FPS=4
CAMERA_MAX_WIDTH=960
CAMERA_JPEG_QUALITY=0.85
DETECTOR_BACKEND=ultralytics
YOLO_MODEL=yolo11_model/yolo11m.pt
MODEL_DEVICE=cpu
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
MIN_DETECTION_AREA=2500
MIN_DETECTION_HEIGHT=60
MAX_DETECTION_WIDTH_HEIGHT_RATIO=1.35
TRACKER_BACKEND=deepsort
MAX_TRACK_AGE=50
TRACKER_N_INIT=3
TRACKER_MAX_IOU_DISTANCE=0.7
TRACKER_MAX_COSINE_DISTANCE=0.2
TRACKER_NN_BUDGET=100
TRACKER_EMBEDDER=mobilenet
TRACKER_EMBEDDER_MODEL_NAME=
TRACKER_EMBEDDER_WEIGHTS=
TRACKER_USE_HALF=false
MATCH_DISTANCE_THRESHOLD=120.0
TRACKED_CLASS_NAMES=person
ALLOWED_VIDEO_EXTENSIONS=.mp4,.avi,.mov,.mkv
